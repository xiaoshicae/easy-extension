{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(mvn:*)",
      "Bash(./gradlew:*)",
      "Bash(npx:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(gpg --version)",
      "Bash(gpg --list-keys:*)",
      "Bash(gpg --list-secret-keys:*)",
      "Bash(gpg --keyserver *:--recv-keys *)",
      "Bash(gpg --keyserver *:--send-keys *)",
      "Bash(gpg --batch --no-tty *:--detach-sign *)",
      "Bash(brew --version)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew install:*)",
      "Bash(jq:*)",
      "Bash(xmllint --noout:*)",
      "Bash(qlmanage:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(claude mcp:*)",
      "Read(//tmp/**)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r /:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(*--no-verify*)",
      "Bash(* --no-verify)",
      "Bash(git commit --no-verify*)",
      "Bash(git push --no-verify*)",
      "Bash(mvn deploy*-DskipTests*)",
      "Bash(mvn deploy*-Dgpg.skip*)",
      "Bash(mvn deploy*-Dmaven.test.skip*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-check.sh"
          }
        ]
      }
    ]
  }
}
